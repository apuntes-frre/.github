root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
quote_type = single

[*.py]
indent_size = 4
quote_type = double

[*.md]
# Markdown usa espacios al final para saltos de línea; no recortar ni reflowar.
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2
